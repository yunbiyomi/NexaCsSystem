	-nexa-text-align : right;
}
.Grid.grd_WF_List2
{
	-nexa-border : 1px solid -nexa-define(--box_border);
	background : -nexa-define(--box_background);
}
.Grid.grd_WF_List2 .body .row .cell
{
	background : -nexa-define(--box_background);
}
.ImageViewer.img_WF_BorderNone
{
	-nexa-border : 0px none;
}
.ListView .body .cell.cell_WF_LstvTitle
{
	font : 700 12px "NotoSansKR-Bold";
}
.ListView .body .cell.cell_WF_LstvSerach .cellbutton
{
	-nexa-icon : url("theme://images/btn_WF_InputSearchN.png");
	-nexa-padding : 0px;
}
.Static.sta_WF_SchLabel
{
	-nexa-padding : 0px 7px 0px 26px;
	background : URL("theme://images/sta_WF_SchLabel.png") no-repeat left;
	color : -nexa-define(--label_text);
	font : 400 -nexa-define(--fontsize_m) "NotoSansKR-Regular";
}
.Static.sta_WF_Label
{
	-nexa-border : 1px solid -nexa-define(--box_border);
	-nexa-padding : 0px 14px 0px 14px;
	-nexa-word-wrap : english;
	background : -nexa-define(--box_background);
	color : -nexa-define(--label_text);
	font : 400 -nexa-define(--fontsize_m)/14px "NotoSansKR-Regular";
}
.Static.sta_WF_LabelBg
{
	-nexa-border : 1px solid -nexa-define(--box_border);
	-nexa-padding : 0px 0px 0px 14px;
	background : #FFFFFF;
	color : -nexa-define(--label_text);
}
.Static.sta_WF_Title
{
	-nexa-padding : 0px 5px 7px 12px;
	-nexa-vertical-align : bottom;
	background : URL("theme://images/sta_WF_Title.png") no-repeat left center;
	font : 700 -nexa-define(--fontsize_l) "NotoSansKR-Bold";
}
.Static.sta_WF_SubTitle
{
	-nexa-padding : 0px 5px 7px 11px;
	-nexa-vertical-align : bottom;
	background : URL("theme://images/sta_WF_SubTitle.png") no-repeat left center;
	font : 400 -nexa-define(--fontsize_l) "NotoSansKR-Regular";
}
.Static.sta_WF_Center
{
	-nexa-text-align : center;
}
.Static.sta_WF_Location
{
	-nexa-word-wrap : none;	
	color : -nexa-define(--text_nm);
	font : -nexa-define(--fontsize_l) "NotoSansKR-Regular";	
}
/***********************************************************************/
/***************************  WORKFRAME END  ***************************/
/***********************************************************************/

/***********************************************************************/
/****************************  POPUP START  ****************************/
/***********************************************************************/
.Button.btn_POP_Confirm,
.Button.btn_POP_Confirm[status=focused]
{
	-nexa-border : 0px none;
	background : -nexa-define(--primary);
	border-radius : 5px;
	color : #FFFFFF;
	font : 400 -nexa-define(--fontsize_m) "NotoSansKR-Bold";
}
.Button.btn_POP_Confirm[status=mouseover],.Button.btn_POP_Confirm[userstatus=pushed],
.Button.btn_POP_Confirm[userstatus=selected]
{
	-nexa-border : 0px none;
	background : -nexa-define(--teriary02);
	color : #FFFFFF;
}
.Button.btn_POP_Confirm[status=disabled]
{
	-nexa-border : 1px solid -nexa-define(--border_nm);
	background : -nexa-define(--background_ds);
	color : -nexa-define(--text_ds);
}
.Button.btn_POP_Cancel,
.Button.btn_POP_Cancel[status=focused]
{
	-nexa-border : 0px none;
	background : -nexa-define(--btn_background);
	border-radius : 5px;
	color : -nexa-define(--text_nm);
	font : 400 -nexa-define(--fontsize_m) "NotoSansKR-Bold";
}
.Button.btn_POP_Cancel[status=mouseover],.Button.btn_POP_Cancel[userstatus=pushed],
.Button.btn_POP_Cancel[userstatus=selected]
{
	-nexa-border : 0px none;
	background : -nexa-define(--teriary02);
	color : #FFFFFF;
}
.Button.btn_POP_Cancel[status=disabled]
{
	-nexa-border : 1px solid -nexa-define(--border_nm);
	background : -nexa-define(--background_ds);
	color : -nexa-define(--text_ds);
}

.TextArea.txt_POP_Text,
.TextArea.txt_POP_Text[status=focused],.TextArea.txt_POP_Text[status=mouseover],
.TextArea.txt_POP_Text[status=readonly]
{
	-nexa-border : 0px none;
	background : -nexa-define(--box_background);
}

/***********************************************************************/
/*****************************  POPUP END  *****************************/
/***********************************************************************/


/*****************************  GUIDE START ****************************/
.Static.sta_WF_GSize
{
	-nexa-text-align : center;
	background: #ff0000;
	color: #000000;
	font: 700 12px "Dotum";
	opacity : 0.3;
}
/******************************  GUIDE END *****************************/

