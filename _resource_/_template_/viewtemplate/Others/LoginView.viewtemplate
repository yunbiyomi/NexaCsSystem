<ViewTemplateInfo version="2.0">
  <ViewTemplate id="LoginView" viewtype="Others" description_en="description of the view template"/>
  <Script version="1.0" type="xscript5.1"><![CDATA[/************************************************************************************************
*  @FileName 	LoginView
*  @Creator 	Tobesoft
*  @CreateDate 	2026.01.02
*  @Desction    Displays data in a basic list format
*  @Version		1.0.0.0
*************************************************************************************************
