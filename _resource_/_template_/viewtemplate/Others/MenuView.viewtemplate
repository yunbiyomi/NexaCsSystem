	/*---------------------------------------------------------------------------------------------*
	* Function    : main
	* Parameter   : 
	*               - fieldarray     : model field list
	*               - contents       : old contents (include <View>)
	*               - viewproperties : attributes for view generation
	* Return      : View contents (source + script) (JSON format)
				ex) {
						"View": {
							"tag": "View",
							"attribute": {
								"id": "View00",
								"viewtype": "FreeForm",
								"taborder": "2",
								"text": "search view",
								"left": "0",
								...
							},
							"Model": [
								{   // with field
									"fieldid": "department",
									"Components": [
									...
									]
								},
								{   // without field
									"fieldid": "",
									"Components": [
									...
									]
								}
							],
							"InitValue": [
							],
							"Objects": [
							],
							"Bind": [
							],
							"Script": {
								"tag": "Script",
								"attribute": {
								},
								"value": ""
							}
						}
					}
	* Description : Generate the view based on the model field and return the results.
	*---------------------------------------------------------------------------------------------*
	*                        !!! This function is required by NexaLAP Studio. !!!                 *
	*                        !!! Do not remove or rename this function. !!!                       *
	*---------------------------------------------------------------------------------------------*/
	this.main = function(fieldarray, contents, viewproperties) {

	  var vResult = "";

		// TODO : Based on model information, generate the view and write the code that returns it.
		/*  // Example code
		var json_contents = JSON.parse(contents);			
