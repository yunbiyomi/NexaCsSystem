			if(!bNotUselabel) {		
		  tempInfo = new Object();	
			  tempInfo.tag = "Static";	
			  tempInfo.attribute = new Object();	
			  tempInfo.attribute.id = "Static"+json_fieldarray.fields[i].id;	
			  tempInfo.attribute.text = json_fieldarray.fields[i].label;	
			  tempInfo.attribute.left = 0;	
			  tempInfo.attribute.top = i*30;	
			  tempInfo.attribute.width = 70;	
			  tempInfo.attribute.height = 20;	
			  ComponentArray.push(tempInfo);	
	  }
					
			tempInfo = new Object();		
			tempInfo.tag = "Edit";		
			tempInfo.attribute = new Object();		
			tempInfo.attribute.id = "Edit"+json_fieldarray.fields[i].id;	
	  
			if(!bNotUselabel) {		
				tempInfo.attribute.left = 70 + 10;	
				tempInfo.attribute.top = i * 30;	
				tempInfo.attribute.width = nViewWidth - 70 - 10;	
				tempInfo.attribute.height = 20;	
			}		
			else		
			{		
				tempInfo.attribute.left = 0;	
				tempInfo.attribute.top = i * 30;	
				tempInfo.attribute.width = nViewWidth;	
				tempInfo.attribute.height = 20;	
			}		
			tempInfo.attribute.text =  json_fieldarray.fields[i].text;;		
					
			ComponentArray.push(tempInfo);		
					
			ModelInfo.Components = ComponentArray;		
			ModelArray.push(ModelInfo);		
		}			
					
		tempInfo = new Object();			
		tempInfo.tag = "View";			
		tempInfo.attribute = json_contents.View.attribute;			
		tempInfo.Model = ModelArray;			
					
		View.View = tempInfo;			
		vResult = JSON.stringify(View);			
	*/

	  
		//Set View Component Information as JSON Object 										
		if(contents){
		  oContents = JSON.parse(contents);	
		}
		
		oContents.View.attribute.viewdataset = "${VIEW_DATASET}";

		if (!oContents.View.Model) {
		  oContents.View.Model = [];
		}
		if (!oContents.View.InitValue) {
		  oContents.View.InitValue = [];
		}
		if (!oContents.View.Objects) {
		  oContents.View.Objects = [];
		}
		if (!oContents.View.Bind) {
		  oContents.View.Bind = [];
		}    


		//Load Script Information Generation Function										
		oContents.View.Script = this.fn_GetScript();	

		//sScript = "this.fn_create= function(){	}"
		vResult = JSON.stringify(oContents, null, "\t");

	//trace("vResult====>"+vResult);	
	//    nexacro.__onNexacroStudioError(">>> __onNexacroStudioError function"+ vResult);
		return vResult;
	};

/************************************************************************************************
 * Functions Related to the main() Execution Flow
 ************************************************************************************************/	
	/*---------------------------------------------------------------------------------------------*											
	 * Function     : fn_GetScript											
	 * Parameter    : 											
	 * Return       : script contents (JSON format)											
	 * Description  : Function to generate <Script> source											
	 *---------------------------------------------------------------------------------------------*/											
	this.fn_GetScript = function(){		
	  var oScript = {};											
	  var sValue 	="";
	//  외부 호출 함수	
		var sValue = "this._cfn_menuCreate = " 
				   + nexacro.replaceAll(nexacro.replaceAll(nexacro.replaceAll(this._cfn_menuCreate.toString(),"\r",""),"\n",""),"\t","")
				   + ";";

	//      top Menu 생성 함수	
			sValue = sValue + "this._cfn_TopMenuCreate = "
				   + nexacro.replaceAll(nexacro.replaceAll(nexacro.replaceAll(this._cfn_TopMenuCreate.toString(),"\r",""),"\n",""),"\t","")
				   + ";"

	//      top Menu click 이벤트 함수
			sValue = sValue + "this._cfn_topMenu_onclick = "
				   + nexacro.replaceAll(nexacro.replaceAll(nexacro.replaceAll(this._cfn_topMenu_onclick.toString(),"\r",""),"\n",""),"\t","")
				   + ";"		

	//      sub menu 생성 함수
			sValue = sValue + "this._cfn_createSubMenu = "
				   + nexacro.replaceAll(nexacro.replaceAll(nexacro.replaceAll(this._cfn_createSubMenu.toString(),"\r",""),"\n",""),"\t","")
				   + ";"		

			sValue = sValue + "this._cfn_createMenu = "
				   + nexacro.replaceAll(nexacro.replaceAll(nexacro.replaceAll(this._cfn_createMenu.toString(),"\r",""),"\n",""),"\t","")
				   + ";"
				   
			sValue = sValue + "this._cfn_menu_onclick = "
				   + nexacro.replaceAll(nexacro.replaceAll(nexacro.replaceAll(this._cfn_menu_onclick.toString(),"\r",""),"\n",""),"\t","")
				   + ";"			   

		oScript = 											
		{											
			"tag": "Script",											
			"attribute": { "type" : "xscript5.1" },											
			"value": sValue											
		}											
													
													
		return oScript;											
	};	
	
/*===============================================================================================*/
/* Model Generation Related Functions                                                            */	
/*===============================================================================================*/	
	

/*===============================================================================================*/
/* List of functions defined inside the script generated by fn_GetScript
/*-----------------------------------------------------------------------------------------------*/
/* Notes: 1. Do not include comments inside these functions.                                      */
/*        2. Escape characters such as '\r, \n, \t' must not be used.                          */
/*===============================================================================================*/
	/*---------------------------------------------------------------------------------------------*
	* Function     : _fnViewOnLoad
	* Description  : Handles the onload event processing for the view component
	*---------------------------------------------------------------------------------------------*/
	this._fnViewOnLoad = function(objForm){
		/* Sets the view form reference so that functions declared in the view can access it */
		// this._ownerForm = objForm;
	};
	
	/*---------------------------------------------------------------------------------------------*
	* Function     : _cfn_menuCreate
	* Description  : 외부 호출 함수
	*---------------------------------------------------------------------------------------------*/
	this._cfn_menuCreate = function(){
	trace('_cfn_menuCreate');  
		var oTopMenuDs = this.parent.getViewDataset();
		this._cfn_TopMenuCreate(oTopMenuDs);
	};

	/*---------------------------------------------------------------------------------------------*
	* Function     : _cfn_TopMenuCreate
	* Description  : top Menu 생성 함수
	*---------------------------------------------------------------------------------------------*/
	this._cfn_TopMenuCreate = function(oTopMenuDs){
		var oMenuBtn = null;
		var sMenuId = '';
		var sMenuNm = '';
		var nLeft = 0;
		var nTop = 0;
		
		var aComponents = this.components;
		for(var i = aComponents.length -1 ; i >= 0 ; i--){
			this.removeChild(aComponents[i].id);
		};
		oTopMenuDs.filter('MENU_LVL==1');
		for(var i = 0 ; i < oTopMenuDs.getRowCount() ; i++){
			sMenuId = 'btn_' + oTopMenuDs.getColumn(i, 'MENU_ID');
			sMenuNm = oTopMenuDs.getColumn(i, 'MENU_NM');
			oMenuBtn = new Button();
			oMenuBtn.init(sMenuId,nLeft,nTop,120,30);
			oMenuBtn.set_text(sMenuNm);
			this.addChild(sMenuId,oMenuBtn);
			oMenuBtn.show();

			oMenuBtn.addEventHandler('onclick',this._cfn_topMenu_onclick, this);
			nLeft = nLeft + 121;
		};
		oTopMenuDs.filter('');    
	};

	/*---------------------------------------------------------------------------------------------*
	* Function     : _cfn_topMenu_onclick
	* Description  : top Menu click 이벤트 함수
	*---------------------------------------------------------------------------------------------*/
	this._cfn_topMenu_onclick = function(obj, e){ 
		var oTopMenuDs = this.parent.getViewDataset();
		var sMenuId = nexacro.replaceAll(obj.name, 'btn_', '');
		var nFindRow = oTopMenuDs.findRow('MENU_ID', sMenuId);
		if(oTopMenuDs.getColumn(nFindRow,'MENU_TYPE')=='F'){
			this._cfn_createSubMenu(sMenuId);
		} else {
			alert('페이지 오픈');
		};
	};

	/*---------------------------------------------------------------------------------------------*
	* Function     : _cfn_createSubMenu
	* Description  : sub menu poupDiv/2레벨 dataset 생성 함수
	*---------------------------------------------------------------------------------------------*/
	this._cfn_createSubMenu = function(sMenuId){
	trace('_cfn_createSubMenu')  ;
		var oForm = this.getOwnerFrame().form;
		var oTopMenuDs = this.parent.getViewDataset();
		var oPdvMenu = oForm['pdvMenu'];

		if( oPdvMenu == null || oPdvMenu == undefined || oPdvMenu == ''){
			oPdvMenu = new PopupDiv();
			oPdvMenu.init('pdvMenu',0,0,0,0);
			oForm.addChild('pdvMenu', oPdvMenu);
			oPdvMenu.show();
			
			oPdvMenu.set_background('white');
			oPdvMenu.set_border('1px solid black');
		};
		
		var oSubMenuDs = oForm['ds_subMenu'];
		if( oSubMenuDs == null || oSubMenuDs == undefined || oSubMenuDs == ''){
			oSubMenuDs = new Dataset();	   
			oSubMenuDs.name='ds_subMenu';
			oForm.addChild('ds_subMenu', oSubMenuDs);
		};
		var sFilter = 'TOP_MENU_ID=="' + sMenuId+'"';
		oTopMenuDs.filter(sFilter);
		oSubMenuDs.copyData(oTopMenuDs, true);
		oTopMenuDs.filter('');
		
		var oMenuDiv = null;
		var sMenuDivId = '';
		var nLeft = 5;
		var nTop = 5;
		var nWidth = 160;
		var nHeight = 10;
		var nRowCnt = 0;
		var nMaxRowCnt = 0;
		var sFilter = '';

		var aComponent = oPdvMenu.form.components;
		for(var i = aComponent.length -1 ; i >= 0 ; i--){
			oPdvMenu.removeChild(aComponent[i].id);
		};

		var oMiddleMenuDs = oForm['ds_middleMenu'];
		if( oMiddleMenuDs == null || oMiddleMenuDs == undefined || oMiddleMenuDs == ''){
			oMiddleMenuDs = new Dataset();	   
			oMiddleMenuDs.name='ds_middleMenu';
			oForm.addChild('ds_middleMenu', oMiddleMenuDs);
		};
	trace(oSubMenuDs.saveXML())  ;
		sFilter = 'MENU_LVL=="2"';
		oSubMenuDs.filter(sFilter);
		oMiddleMenuDs.copyData(oSubMenuDs, true);
		oSubMenuDs.filter('');
		for(var i = 0 ; i < oMiddleMenuDs.getRowCount() ; i++){
			sMenuDivId = oMiddleMenuDs.getColumn(i, 'MENU_ID');
	trace('sMenuDivId====>'+sMenuDivId)    ;
			sFilter = 'MENU_ID=="' + sMenuDivId + '" || UP_MENU_ID=="' + sMenuDivId + '"';
			oSubMenuDs.filter(sFilter);
			nRowCnt = oSubMenuDs.getRowCount();
			oSubMenuDs.filter('');
			nHeight = nRowCnt * 30 + nRowCnt * 2 + 10;
			oMenuDiv = new Div();
			oMenuDiv.init('div_'+ sMenuDivId, nLeft, nTop, nWidth, nHeight);
			oPdvMenu.addChild('div_'+ sMenuDivId, oMenuDiv);
			oMenuDiv.show();
			nLeft = nLeft + nWidth;
			if(nRowCnt > nMaxRowCnt){
				nMaxRowCnt = nRowCnt;
			};
			
			this._cfn_createMenu(sMenuDivId, oMenuDiv);
		};
		nDivWidth = oMiddleMenuDs.getRowCount() * nWidth + 10;
		nDivHeight = nMaxRowCnt * 30 + nMaxRowCnt * 2 + 20;
		oPdvMenu.trackPopupByComponent(this['btn_'+sMenuId], 0, 33, nDivWidth, nDivHeight, '', false);
	};

	/*---------------------------------------------------------------------------------------------*
	* Function     : _cfn_createMenu
	* Description  : 
	*---------------------------------------------------------------------------------------------*/
	this._cfn_createMenu = function(sMenuDivId, oMenuDiv){
		var oForm = this.getOwnerFrame().form;
		var sMenuType = '';
		var oCompo = null;
		var sCompoId = '';
		var sCompoNm = '';
		var nLeft = 5;
		var nTop = 7;
		var oMenuDs= oForm['ds_subMenu'];
		var sFilter = 'MENU_ID=="' + sMenuDivId + '" || UP_MENU_ID=="' + sMenuDivId + '"';
		oMenuDs.filter(sFilter);	
		for(var i = 0 ; i < oMenuDs.getRowCount() ; i++){
			sMenuType = oMenuDs.getColumn(i, 'MENU_TYPE');
			sCompoId = 'menu_'+ oMenuDs.getColumn(i, 'MENU_ID');
			sCompoNm = oMenuDs.getColumn(i, 'MENU_NM');

			if(sMenuType == 'F'){
				oCompo = new Static();
				nLeft = 5;
			} else { 
				oCompo = new Button();
				nLeft = 8;
			};
			oCompo.init(sCompoId, nLeft, nTop, 150, 30);
			oMenuDiv.addChild(sCompoId, oCompo);
			oCompo.set_text(sCompoNm);
			oCompo.show();
			
			if(sMenuType == 'P'){
			oCompo.addEventHandler('onclick',this._cfn_menu_onclick, this);
			};
			
			nTop = nTop + 31;
		};
		oMenuDs.filter('');	  
	};

	/*---------------------------------------------------------------------------------------------*
	* Function     : _cfn_menu_onclick
	* Description  : 
	*---------------------------------------------------------------------------------------------*/
	this._cfn_menu_onclick = function(obj, e){
		var sMenuId = nexacro.replaceAll(obj.name, 'menu_', '');
		var oForm = this.getOwnerFrame().form;
		var oMenuDs= oForm['ds_subMenu'];
		
		var nRow = oMenuDs.findRow('MENU_ID', sMenuId);
		var sUrl = oMenuDs.getColumn(nRow, 'PRIFIX') + '::' + oMenuDs.getColumn(nRow, 'PGM_URL');
	trace('sUrl ===> ' + sUrl)  ;
	  if(sUrl != null && sUrl !=undefined && sUrl !=''){
		  oForm.div_work.set_url(sUrl);    
	  } else {
		alert('연결 Url이 존재 하지 않습니다.');
	  };

		oForm['pdvMenu'].closePopup();
	};]]>
  </Script>
