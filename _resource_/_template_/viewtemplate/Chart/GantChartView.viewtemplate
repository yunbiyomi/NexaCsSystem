	/*---------------------------------------------------------------------------------------------
	 * Function     : fn_GetObjects
	 * Parameter    :
	 *                - this.oFieldArray : model field data
	 *                - this.oContents : view contents
	 *                - this.oViewProperties : attributes for view generation
	 * Return       : objects contents (JSON format)
	 * Description  : Function to generate <Objects> source
	 *---------------------------------------------------------------------------------------------*/
	this.fn_GetObjects = function()
	{
		//Initialize Object
		var oObjects = [];
		var oInner = [];

		// InnerDataset 정보
		oInner = this.lfn_GetInnerDataset(this.oUseFieldArray);

		oObjects = oObjects.concat(oInner);

		//Return Object Information
		return oObjects;
	};
	
	/*---------------------------------------------------------------------------------------------
	 * Function     : fn_GetScript
	 * Parameter    :
	 *                - this.oFieldArray : model field data
	 *                - this.oContents : view contents
	 *                - this.oViewProperties : attributes for view generation
	 * Return       : script contents (JSON format)
	 * Description  : Function to generate <Script> source
	 *---------------------------------------------------------------------------------------------*/
	this.fn_GetScript = function()
	{

		//Initialize Script Information
		var oScript = {};

		var sValue = "this._fnViewOnLoad = "
				   + nexacro.replaceAll(nexacro.replaceAll(nexacro.replaceAll(this._fnViewOnLoad.toString(),"\r",""),"\n",""),"\t","")
				   + ";"

		sValue = sValue + "this._fn_div_form_onhscroll = "
				   + nexacro.replaceAll(nexacro.replaceAll(nexacro.replaceAll(this._fn_div_form_onhscroll.toString(),"\r",""),"\n",""),"\t","")
				   + ";"

		sValue = sValue + "this._fn_div_form_onvscroll = "
				   + nexacro.replaceAll(nexacro.replaceAll(nexacro.replaceAll(this._fn_div_form_onvscroll.toString(),"\r",""),"\n",""),"\t","")
				   + ";"

		sValue = sValue + "this._fn_initGantt = "
				   + nexacro.replaceAll(nexacro.replaceAll(nexacro.replaceAll(this._fn_initGantt.toString(),"\r",""),"\n",""),"\t","")
				   + ";"

		sValue = sValue + "this._fn_ganttText = "
				   + nexacro.replaceAll(nexacro.replaceAll(nexacro.replaceAll(this._fn_ganttText.toString(),"\r",""),"\n",""),"\t","")
				   + ";"

		sValue = sValue + "this._fn_nXPosition = "
				   + nexacro.replaceAll(nexacro.replaceAll(nexacro.replaceAll(this._fn_nXPosition.toString(),"\r",""),"\n",""),"\t","")
				   + ";"

		sValue = sValue + "this._fn_creatGantt = "
				   + nexacro.replaceAll(nexacro.replaceAll(nexacro.replaceAll(this._fn_creatGantt.toString(),"\r",""),"\n",""),"\t","")
				   + ";"	

		sValue = sValue + "this._fn_deleteGantt = "
				   + nexacro.replaceAll(nexacro.replaceAll(nexacro.replaceAll(this._fn_deleteGantt.toString(),"\r",""),"\n",""),"\t","")
				   + ";"	

		sValue = sValue + "this._vfn_GetLastDate = "
				   + nexacro.replaceAll(nexacro.replaceAll(nexacro.replaceAll(this._vfn_GetLastDate.toString(),"\r",""),"\n",""),"\t","")
				   + ";"	
		oScript =
		{
			"tag": "Script",
			"attribute": { "type" : "xscript5.1" },
			"value": sValue
		}

		//Return Script Information
		return oScript;
	};

	/*---------------------------------------------------------------------------------------------
	 * Function     : fn_GetColumns
	 * Parameter    :
	 *                - oBaseLayout : base layout data
	 * Return       : column(s) data of grid format
	 * Description  : Function to generate <Column> source
	 *---------------------------------------------------------------------------------------------*/
	this.fn_GetColumns = function(oBaseLayout)
	{

		var oColumns = [];

		//Create Column Tags based on number of Default Layout Columnsize
		//nCount = oBaseLayout.columnsize.length;
		for(var i=0;i<60;i++)
		{
			oColumns[oColumns.length] =
			{
				"tag": "Column",
				"attribute": {"size": "40", "band": "body"}
			}
		}

		//Return Column Information
		return oColumns;
	}
	
	/*---------------------------------------------------------------------------------------------
	 * Function     : fn_GetRows
	 * Parameter    :
	 *                - oBaseLayout : base layout data
					  - oHeadLayout : head layout data
					  - oBodyLayout : body layout data
					  - oSummLayout : summ layout data
	 * Return       : row(s) data of grid format
	 * Description  : Function to generate <Row> source
	 *---------------------------------------------------------------------------------------------*/
	this.fn_GetRows = function(oBaseLayout, oHeadLayout, oBodyLayout, oSummLayout)
	{

		var nCount;
		var oRows = [];

		oRows[oRows.length] = {
							"tag": "Row",
							"attribute": {"size": "26", "band": "head"}
						};
		oRows[oRows.length] = {
							"tag": "Row",
							"attribute": {"size": "24", "band": "head"}
						};					

		//Return Raw Information
		return oRows;
	}
	
	/*---------------------------------------------------------------------------------------------
	 * Function     : fn_GetHeads
	 * Parameter    :
	 *                - oBaseLayout : base layout data
					  - oHeadLayout : head layout data
	 * Return       : head band data of grid format
	 * Description  : Function to generate <Band id="head"> source
	 *---------------------------------------------------------------------------------------------*/
	this.fn_GetHeads = function(oBaseLayout, oHeadLayout)
	{
		var oHeads = [];	
		var aMonth = ["1월","2월","3월","4월","5월","6월","7월","8월","9월","10월","11월","12월"];
		var aWeek = ["1","2","3","4","5"];
		var nCol = 0;
		for(var i = 0 ; i < 12 ; i++){
			oHeads[oHeads.length] =
					{
						"tag": "Cell",
						"attribute":
						{
							"col" : nCol, "colspan" : "5", "text" : aMonth[i]
						}
					};				
			for(var j = 0 ; j < 5 ; j++){
				oHeads[oHeads.length] =
						{
							"tag": "Cell",
							"attribute":
							{
								"row" : "1", "col" : nCol, "text" : aWeek[j]
							}
						};
				nCol++;		
			}
		}
		return oHeads;
	}
	
	/*---------------------------------------------------------------------------------------------
	 * Function     : fn_GetBodys
	 * Parameter    :
	 *                - oBaseLayout : base layout data
					  - oBodyLayout : body layout data
	 * Return       : body band data of grid format
	 * Description  : Function to generate <Band id="body"> source
	 *---------------------------------------------------------------------------------------------*/
	this.fn_GetBodys = function(oBaseLayout, oBodyLayout)
	{
		var oBodys = [];

		for(var i = 0 ; i < 60 ; i++){
			if((i+1%5) == 0){
				oBodys[oBodys.length] =
						{
							"tag": "Cell",
							"attribute":
							{
								"col" : i,
							}
						};	
			} else {
				oBodys[oBodys.length] =
						{
							"tag": "Cell",
							"attribute":
							{
								"col" : i,
								"border" : "1px solid #e2e0df,0px solid #e2e0df,1px solid #e2e0df,1px solid #e2e0df"
							}
						};	
			}
		
		}
		return oBodys;
	}
	
	/*---------------------------------------------------------------------------------------------
	 * Function     : fn_GetInitValue
	 * Parameter    :
	 *                - this.oFieldArray : model field data
	 *                - this.oContents : view contents
	 *                - this.oViewProperties : attributes for view generation
	 * Return       : initvalue contents (JSON format)
	 * Description  : Function to generate <InitValue> source
	 *---------------------------------------------------------------------------------------------*/
	this.fn_GetInitValue = function()
	{
		var oInitValue = [];
		/*
