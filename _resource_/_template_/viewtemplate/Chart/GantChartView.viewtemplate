/*===============================================================================================*/
	/*---------------------------------------------------------------------------------------------*
	* Function     : _fnViewOnLoad
	* Description  : Handles the onload event processing for the view component
	*---------------------------------------------------------------------------------------------*/
	this._fnViewOnLoad = function(objForm){
		/* Sets the view form reference so that functions declared in the view can access it */
		this._ownerForm = objForm;
/*nexacro.trace("this._ownerForm====>"+objForm.div_form.form.gps_schedule);*/
	};
	
	/*---------------------------------------------------------------------------------------------*
	* Function     : _fn_div_form_onhscroll
	* Description  : div_form Hscroll 이벤트 함수
	*---------------------------------------------------------------------------------------------*/
	this._fn_div_form_onhscroll = function(obj,e){
		this.Master.form.grd_head.hscrollbar.set_pos(e.pos);
	};

	/*---------------------------------------------------------------------------------------------*
	* Function     : _fn_div_form_onvscroll
	* Description  : div_form Vscroll 이벤트 함수
	*---------------------------------------------------------------------------------------------*/
	this._fn_div_form_onvscroll = function(obj,e){
		this.Master.form.div_user.form.vscrollbar.set_pos(e.pos);
	};

	/*---------------------------------------------------------------------------------------------*
	* Function     : _fn_initGantt
	* Description  : 
	*---------------------------------------------------------------------------------------------*/
	this._fn_initGantt = function(oDataSet, oSearchDs){
		var aColor = new Array("#C5B656","#5CE3AA","#D47EEB","#FDBA6F","#6FAAFD","#FD6F71","#D1DD28","#74DFDF","#FFBFA2","#AAADCD");
		var sUserId = "";
		var sFind = "";
		var nCellHeight = 28;
		var aPosition = new Array();
		var sColor;
		var sText;

		var oScheduleUser = this.parent.getViewDataset();
		for(var i = 0 ; i < oScheduleUser.getRowCount() ; i++){
			sUserId = oScheduleUser.getColumn(i, "USER_ID");

			sFind = "USER_ID=='"+sUserId+"'";
			oDataSet.filter(sFind);
			for(var j = 0 ; j < oDataSet.getRowCount() ; j++){
				sGantId  = oDataSet.getColumn(j,"PROJECT_ID")+"_";
				sGantId += oDataSet.getColumn(j,"REQUEST_SEQ");

				aPosition = this._fn_nXPosition(j, oDataSet, oSearchDs);
				nX = aPosition[0];
				nY = i * nCellHeight;
				nWidth = aPosition[1] - aPosition[0];
				if(oDataSet.getColumn(j,"PLAN_INPUT_FLAG")=="01"){
					sColor = aColor[8];
				} else {
					if(oDataSet.getColumn(j,"PART_ID")=="Developer"){
						sColor = aColor[0];
					} else if(oDataSet.getColumn(j,"PART_ID")=="Publisher"){
						sColor = aColor[1];
					} else if(oDataSet.getColumn(j,"PART_ID")=="Designer"){
						sColor = aColor[2];
					} else if(oDataSet.getColumn(j,"PART_ID")=="Planner"){
						sColor = aColor[3];
					} else if(oDataSet.getColumn(j,"PART_ID")=="Manager"){
						sColor = aColor[4];
					} else {  /*"BREAK"*/
						sColor = aColor[9];
					}
				}
				sText = this._fn_ganttText(j,oDataSet);
				this._fn_creatGantt(sGantId, nX, nY, nWidth, nCellHeight, sText, "#ffffff", sColor);
			}
			oDataSet.filter("");
		}		
	};
		
	/*---------------------------------------------------------------------------------------------*
	* Function     : _fn_ganttText
	* Description  : 
	*---------------------------------------------------------------------------------------------*/	
	this._fn_ganttText = function(nRow, oDataSet){
		var sFromDt = oDataSet.getColumn(nRow,"START_DATE");
		var sFromYear  = parseInt(sFromDt.substr(0,4));
		var sFromMonth = parseInt(sFromDt.substr(4,2));
		var sFromDay   = parseInt(sFromDt.substr(6,8));
		
		var sToDt = oDataSet.getColumn(nRow,"END_DATE");
		var sToYear  = parseInt(sToDt.substr(0,4));
		var sToMonth = parseInt(sToDt.substr(4,2));
		var sToDay   = parseInt(sToDt.substr(6,8));
		
		var sReturn = "";
		sReturn  = oDataSet.getColumn(nRow,"PROJECT_NM") +"(";
		sReturn += oDataSet.getColumn(nRow,"CLIENT") +")\n";
		sReturn += sFromYear+"/"+sFromMonth+"/"+sFromDay+"-";
		sReturn += sToYear+"/"+sToMonth+"/"+sToDay+" : ";
		sReturn += oDataSet.getColumn(nRow,"PART_ID");

		return sReturn;   
	};
		
	/*---------------------------------------------------------------------------------------------*
	* Function     : _fn_nXPosition
	* Description  : 
	*---------------------------------------------------------------------------------------------*/		
	this._fn_nXPosition = function(nRow, oDataSet, oSearchDs){
		var aReturn = new Array();
		var sFirstDay;
		var sFirstWeek;
		var sFromWeek= 0;
		var sToWeek = 0;
		var nStartPosition = 0;
		var nEndPosition = 0;
		var nMonthWidth =200;
		
		var sFromDt = oDataSet.getColumn(nRow,"START_DATE");
		var sFromYear  = parseInt(sFromDt.substr(0,4));
		var sFromMonth = parseInt(sFromDt.substr(4,2));
		var sFromDay   = parseInt(sFromDt.substr(6,8));
		
		var sStandardYear = oSearchDs.getColumn(0,"STANDARD_YEAR");
		if(sFromYear <  sStandardYear){
			nStartPosition = sFromWeek
		} else {
			nStartPosition = (nexacro.toNumber(sFromMonth)-1) * nMonthWidth;
			nLastDay = parseInt(this._vfn_GetLastDate(sFromDt).substr(6,8));
			nDayWidth = nexacro.round(nMonthWidth/nLastDay,2);
			nStartPosition = nStartPosition + ((sFromDay-1) * nDayWidth);
		}
		aReturn[0] = nStartPosition;
		var sToDt = oDataSet.getColumn(nRow,"END_DATE");
		var sToYear  = parseInt(sToDt.substr(0,4));
		var sToMonth = parseInt(sToDt.substr(4,2));
		var sToDay   = parseInt(sToDt.substr(6,8));

		if(sToYear >  sStandardYear){
			nStartPosition = 12 * nMonthWidth;
		} else {
			nStartPosition = (nexacro.toNumber(sToMonth)-1) * nMonthWidth;
			nLastDay = parseInt(this._vfn_GetLastDate(sToDt).substr(6,8));
			nDayWidth = nexacro.round(nMonthWidth/nLastDay,2);
			nStartPosition = nStartPosition + (sToDay * nDayWidth);
		}
		aReturn[1] = nStartPosition;
		return aReturn;
	};
		
	/*---------------------------------------------------------------------------------------------*
	* Function     : _fn_creatGantt
	* Description  : 
	*---------------------------------------------------------------------------------------------*/	
	this._fn_creatGantt = function(sGantId, nX, nY, nWidth, nHgight,  sText, sTextColor, sColor){
		var oMainGant = this.div_form.form.gps_schedule.getObjectByID("MAIN_GANT");
		
		var oGroup = new nexacro.GraphicsGroup;
		oGroup.set_x(nX);
		oGroup.set_y(nY);
		oMainGant.addChild("G_"+sGantId, oGroup);
		
		var objRect = new nexacro.GraphicsRect;
		objRect.set_x(0);
		objRect.set_y(0);
		objRect.set_width(nWidth);
		objRect.set_height(nHgight);
		objRect.set_fillstyle(sColor);
		objRect.set_strokepen( "1px solid darkgray" );
		oGroup.addChild("R_"+ sGantId, objRect);
		
		var oText = new nexacro.GraphicsText;
		oText.set_x(nWidth/2);
		oText.set_y(nHgight/2);
		oText.set_text(sText);
		oText.set_textAlign("center");
		oText.set_verticalAlign("middle");
		oText.set_font( "8pt arial, sans-serif" );
		oText.set_color(sTextColor);
		oGroup.addChild("T_"+ sGantId, oText);	
		
		
		this.div_form.form.gps_schedule.redraw();
	};
		
	/*---------------------------------------------------------------------------------------------*
	* Function     : _fn_deleteGantt
	* Description  : 
	*---------------------------------------------------------------------------------------------*/		
	this._fn_deleteGantt = function(){
		var oMainGant = this.div_form.form.gps_schedule.getObjectByID("MAIN_GANT");
		oMainGant.clear();
		this.div_form.form.gps_schedule.redraw();
	};


	/*---------------------------------------------------------------------------------------------*
	* Function     : _vfn_GetLastDate
	* Description  : @class 년월을 입력받아 마지막 일를 반환한다(년월) <br>
	* 				 @param {String} strDate - 6 / 8 자리의 숫자로 된 날짜(YYYYMM)
	*				 @return {String} 해당월의 마지막날 8자리
	*---------------------------------------------------------------------------------------------*/	
	this._vfn_GetLastDate = function(strDate)
	{
		var s = "";
		if (strDate == null) {
			var date = (new Date()).addMonth(1);
		} else {
			var date = new Date(parseInt(strDate.substr(0,4)),parseInt(strDate.substr(4,2)),1);
		}

		date = (new Date(date)).addDate((new Date(date)).getDate()*-1);

		s = (new Date(date)).getFullYear()
		  + (((new Date(date)).getMonth() + 1) + "").padLeft(2, '0')
		  + ((new Date(date)).getDate() + "").padLeft(2, '0');

		return (s);
	};]]>
  </Script>
