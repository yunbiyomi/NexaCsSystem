      <Method name="getTextSize" group="" async="false" usecontextmenu="false" deprecated="false" unused="false" requirement="Edge,Chrome,Safari,Firefox,Windows NRE,macOS NRE,Android NRE,iOS/iPadOS NRE,Android Default Web Browser,iOS/iPadOS Default Web Browser" description="引数として渡された値に基づいて、テキストが表示される領域のサイズを計算して返すメソッドです。">
        <Syntax text="nexacro.getTextSize( strText, strFont [, nLimitWidth, strWordWrap [, refObj]] );&#xA;nexacro.getTextSize( strText, strFont [, refObj] );">
          <Return type="Object" description="引数に基準に計算されたテキストが表示される領域のサイズ情報をオブジェクトとして返します。&#xA;&#xA;返されたオブジェクトの「nx」プロパティにテキストの横サイズが保存されます。&#xA;返されたオブジェクトの「ny」プロパティにテキストの縦サイズが保存されます。" />
          <Arguments>
            <Argument name="nLimitWidth" type="Number" in="false" out="false" option="false" variable="false" description="テキストが表示される領域の最大幅をpixel単位の数値として指定します。&#xA;&#xA;strWordWrap値が「none」もしくは「line」の場合、nLimitWidthに設定された値は無視されます。&#xA;strWordWrap値が「char」もしくは「english」の場合、nLimitWidth値に合わせてテキストが改行されて表示されます。" />
            <Argument name="refObj" type="Object" in="false" out="false" option="false" variable="false" description="strFontの単位が「em」である場合、相対的なサイズを設定する基準コンポーネント（オブジェクト）を指定します。" />
            <Argument name="strFont" type="String" in="false" out="false" option="false" variable="false" description="テキストに適用されるフォント情報をfontプロパティの形式に合わせて指定します。&#xA;&#xA;コンポーネントのfontプロパティに値が設定されている場合は、fontプロパティを設定することができます。" />
            <Argument name="strText" type="String" in="false" out="false" option="false" variable="false" description="画面に表示されるテキストを指定します。" />
            <Argument name="strWordWrap" type="String" in="false" out="false" option="false" variable="false" description="テキストが改行される基準を指定します。&#xA;&#xA;「none」に設定した場合、テキストに含まれている改行文字とnLimitWidth値が無視され、1行で表示されます。&#xA;「line」に設定した場合、nLimitWidth値は無視され、テキストに含まれた改行文字を基準に改行されます。&#xA;「char」に設定した場合、nLimitWidth値を基準に文字単位で改行されます。&#xA;「english」に設定した場合、nLimitWidth値を基準に文字単位で改行されます。&#xA;&#xA;「char」、「english」に設定した場合、テキストに含まれる改行文字によっても改行されます。" />
          </Arguments>
        </Syntax>
      </Method>
