          <Arguments>
            <Argument name="nHeight" type="Number" in="false" out="false" option="false" variable="false" description="モードレスウィンドウとして表示するChildFrameのheight値を指定します。" />
            <Argument name="nLeft" type="Number" in="false" out="false" option="false" variable="false" description="モードレスウィンドウとして表示するChildFrameのleft値を指定します。" />
            <Argument name="nTop" type="Number" in="false" out="false" option="false" variable="false" description="モードレスウィンドウとして表示するChildFrameのtop値を指定します。" />
            <Argument name="nWidth" type="Number" in="false" out="false" option="false" variable="false" description="モードレスウィンドウとして表示するChildFrameのwidth値を指定します。" />
            <Argument name="objArguList" type="Object" in="false" out="false" option="false" variable="false" description="モードレスウィンドウとして表示するChildFrameに追加される変数リストを&quot;{変数名:変数値, 変数名:変数値}&quot;のような形式で指定します。" />
            <Argument name="objOpener" type="Object" in="false" out="false" option="false" variable="false" description="openerとして設定するFormをオブジェクト型で指定します。&#xA;&#xA;値を省略した場合はobjParentFrameパラメータに指定されたFormが設定されます。" />
            <Argument name="objParentFrame" type="Object" in="false" out="false" option="false" variable="false" description="モードレスウィンドウとして表示するChildFrameの親FrameをObject型で指定します。&#xA;&#xA;nullを設定した場合は親が設定されません。" />
            <Argument name="strExtOpenStyle" type="String" in="false" out="false" option="false" variable="false" description="ChildFrameが表示される際に追加で適用するプロパティを&quot;プロパティ名1=プロパティ値1 プロパティ名2=プロパティ値2&quot;のような形式で指定します。&#xA;環境によって設定できるプロパティが異なり、各プロパティは空白（Space）で区切ります。&#xA;&#xA;* Windows NREでのみサポートするプロパティで、省略した場合はfalseが適用されます。&#xA;　noactivateプロパティを「true」に設定した場合、表示されたChildFrameは有効になりません。&#xA;　noactivateプロパティを「false」に設定した場合、表示されたChildFrameが有効になり、フォーカスを持ちます。&#xA;　noactivateプロパティは表示されたChildFrameにフォーカスを移動したくない場合に使用します。" />
            <Argument name="strFormURL" type="String" in="false" out="false" option="false" variable="false" description="モードレスウィンドウとして表示するChildFrameにロードされるFormをURL形式で指定します。" />
            <Argument name="strID" type="String" in="false" out="false" option="false" variable="false" description="モードレスウィンドウとして表示するChildFrameのIDを文字列として指定します。" />
            <Argument name="strOpenStyle" type="String" in="false" out="false" option="false" variable="false" description="モードレスウィンドウとして表示するChildFrameに適用されるプロパティ値を&quot;プロパティ名1=プロパティ値1 プロパティ名2=プロパティ値2&quot;のような形式で指定します。&#xA;&#xA;ChildFrameの一部のプロパティを設定することができ、各プロパティは空白（Space）で区切ります。&#xA;ChildFrameのCSS関連のプロパティは設定することができません。（例. background、-nexa-border、fontなど）&#xA;&#xA;* 以下のプロパティ、プロパティの設定値は、openメソッド実行時に特定の実行環境でのみサポートされます。&#xA;dragmovetypeプロパティの「all」値は、Windows NREでのみサポートされます。&#xA;layeredプロパティは、Windows NREおよびmacOS NREでのみサポートされます。&#xA;openstatusプロパティの「maximize」値は、Windows NREでのみサポートされます。&#xA;openstatusプロパティの「normal」および「minimize」値は、Windows NREでのみサポートされます。&#xA;showtitlebarプロパティは、Windows NREでのみサポートされます。&#xA;showstatusbarプロパティは、Windows NREでのみサポートされます。" />
            <Argument name="strReturnType" type="String" in="false" out="false" option="false" variable="false" description="戻り値の型を指定します。&#xA;値を設定しない場合は、モードレスウィンドウの表示成功／失敗を返します。&#xA;値を設定した場合は、以下のとおり戻り値の型が決定されます。&#xA;- &quot;promise&quot;：Promiseオブジェクトを返します。" />
          </Arguments>
        </Syntax>
      </Method>
