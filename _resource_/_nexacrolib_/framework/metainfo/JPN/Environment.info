      <Method name="findAccessibility" group="" async="false" usecontextmenu="false" deprecated="false" unused="false" requirement="Chrome,Windows NRE,Android NRE,iOS/iPadOS NRE,Android Default Web Browser,iOS/iPadOS Default Web Browser" description="パラメータとして渡されたテキストがアクセシビリティ関連のプロパティ値に設定されたオブジェクトを特定の範囲で検索して返すメソッドです。">
