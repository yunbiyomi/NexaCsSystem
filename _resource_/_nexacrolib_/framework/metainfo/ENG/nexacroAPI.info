      <Method name="loadStringResource" group="Normal" async="false" usecontextmenu="false" deprecated="false" unused="false" requirement="Edge,Chrome,Safari,Firefox,Opera,Windows NRE,macOS NRE,Android NRE,iOS/iPadOS NRE,Android Default Web Browser,iOS/iPadOS Default Web Browser" description="This method loads the StringResource corresponding to the specified language.">
        <Syntax text="nexacro.loadStringResource(strLang[, strUrl]);&#xA;nexacro.loadStringResource(strUrl);">
          <Return type="" description="" />
          <Arguments>
            <Argument name="strLang" type="String" in="false" out="false" option="false" variable="false" description="&quot;Set the target language to load from StringResource.&#xD;&#xA;&#xD;&#xA;If only the strLang parameter value is set, the method does not work in the following situations.&#xD;&#xA;- When there is no generated StringResource file&#xD;&#xA;- When the Environment.usestringresource property value is false&#xD;&#xA;&quot;" />
            <Argument name="strUrl" type="String" in="false" out="false" option="false" variable="false" description="&quot;Set the service URL for updating StringResource information as a string.&#xD;&#xA;&#xD;&#xA;- When strUrl parameter value is set, it runs regardless of the Environment.usestringresource property value.&#xD;&#xA;- The returned value must be in JSON file format including the specified language data.&#xD;&#xA;&#xD;&#xA;* When the strLang parameter value is set&#xD;&#xA;The corresponding language data is searched and loaded based on the strLang parameter value.&#xD;&#xA;Depending on the URL string format, the lang=[strLang] parameter is added when calling the URL.&#xD;&#xA;- If there is a parameter: &amp;lang=[strLang] added&#xD;&#xA;  e.g.) http://dummy.com/i18n?test=true&#xD;&#xA;       -&gt; http://dummy.com/i18n?test=true&amp;lang=ja&#xD;&#xA;- If there is no parameter: ?lang=[strLang] added&#xD;&#xA;  e.g.) http://dummy.com/i18n&#xD;&#xA;       -&gt; http://dummy.com/i18n?lang=ja&#xD;&#xA;&#xD;&#xA;* If only the strUrl parameter value is set&#xD;&#xA;The corresponding language data is searched and loaded based on the Environment.locale property value.&#xD;&#xA;&#xD;&#xA;&quot;" />
          </Arguments>
        </Syntax>
      </Method>
      <Method name="loadStyle" group="" async="false" usecontextmenu="false" deprecated="false" unused="false" requirement="Edge,Chrome,Safari,Firefox,Opera,Windows NRE,macOS NRE,Android NRE,iOS/iPadOS NRE,Android Default Web Browser,iOS/iPadOS Default Web Browser" description="The method to load and apply an XCSS file to the application.">
