          </Arguments>
        </Syntax>
      </Method>
      <Method name="open" group="" async="false" usecontextmenu="false" deprecated="false" unused="false" requirement="Edge,Chrome,Safari,Firefox,Opera,Windows NRE,macOS NRE,Android NRE,iOS/iPadOS NRE,Android Default Web Browser,iOS/iPadOS Default Web Browser" description="This is a method that displays a dynamically created ChildFrame as a Modeless Window.">
        <Syntax text="nexacro.open( strID, strFormURL, objParentFrame, {objArguList}, strOpenStyle, nLeft, nTop [, nWidth, nHeight [, objOpener [, strExtOpenStyle [, strReturnType ]]]])">
          <Return type="Boolean, Object" description="&quot;The return value type depends on the returnType setting.&#xD;&#xA;&#xD;&#xA;- If not set: (Boolean) &#xD;&#xA;  Returns whether the modeless window was displayed successfully.&#xD;&#xA;&#xD;&#xA;- &quot;&quot;promise&quot;&quot;: (Object)&#xD;&#xA;  Returns a Promise object.&#xD;&#xA;  The Promise object is a standard JavaScript built-in object.&#xD;&#xA;  Internally, resolve is executed when the modeless window is closed.&quot;" />
          <Arguments>
            <Argument name="nHeight" type="Number" in="false" out="false" option="false" variable="false" description="It specifies the height of a ChildFrame that will be displayed as a modeless window.." />
            <Argument name="nLeft" type="Number" in="false" out="false" option="false" variable="false" description="It specifies the coordinates of the left edge of a ChildFrame that will be displayed as a modeless window." />
            <Argument name="nTop" type="Number" in="false" out="false" option="false" variable="false" description="It specifies the coordinates of the top edge of a ChildFrame that will be displayed as a modeless window.." />
            <Argument name="nWidth" type="Number" in="false" out="false" option="false" variable="false" description="It specifies the width of a ChildFrame that will be displayed as a modeless window.." />
            <Argument name="objArguList" type="Object" in="false" out="false" option="false" variable="false" description="It specifies a list of variables to add to a ChildFrame that will be displayed as a modeless window, with the format {variable name:variable value, variable name:variable value}." />
            <Argument name="objOpener" type="Object" in="false" out="false" option="false" variable="false" description="It specifies a Form object that will serve as an opener.&#xA;&#xA;If unspecified, this parameter will take the Form defined by the objParentFrame parameter." />
            <Argument name="objParentFrame" type="Object" in="false" out="false" option="false" variable="false" description="This is an object that will serve as the parent of the ChildFrame displayed as a modeless window.&#xA;&#xA;If you specify &quot;null&quot;, nothing will be defined as the parent." />
            <Argument name="strExtOpenStyle" type="String" in="false" out="false" option="false" variable="false" description="You can specify additional properties of the ChildFrame with the format &quot;Property1=value1 Property2=value2&quot;.&#xA;Applicable properties vary according to environments and properties are separated by spaces.&#xA;&#xA;&#xA;* The noactivate property is applicable only to the Windows NRE, and the default value of the property is &quot;false&quot;.&#xA;If you set the noactivate property to &quot;true&quot;, the displayed ChildFrame will not be activated.&#xA;If you set noactivate to &quot;false&quot;, the displayed ChildFrame will be activated and focused.&#xA;The noactivate property is used to prevent focus from going to the displayed ChildFrame." />
            <Argument name="strFormURL" type="String" in="false" out="false" option="false" variable="false" description="It specifies the URL of a Form that will be loaded onto the ChildFrame displayed as a modeless window." />
            <Argument name="strID" type="String" in="false" out="false" option="false" variable="false" description="It specifies the ID of a ChildFrame to display as modeless window." />
            <Argument name="strOpenStyle" type="String" in="false" out="false" option="false" variable="false" description="&quot;Set the property values to be applied to the ChildFrame to be displayed as a Modeless Window in the format &quot;&quot;propertyName1=propertyValue1 propertyName2=propertyValue2&quot;&quot;.&#xD;&#xA;&#xD;&#xA;Some properties of the ChildFrame can be set, and each property is separated by a space.&#xD;&#xA;CSS-related properties of the ChildFrame cannot be set. (Example: background, -nexa-border, font, etc.)&#xD;&#xA;&#xD;&#xA;The &quot;&quot;all&quot;&quot; value of the &quot;&quot;dragmovetype&quot;&quot; property is supported only in Windows NRE.&#xD;&#xA;The &quot;&quot;layered&quot;&quot; property is supported only in Windows NRE and macOS NRE.&#xD;&#xA;The value &quot;&quot;maximize&quot;&quot; of the “openstatus” property is supported only in Windows NRE.&#xD;&#xA;The &quot;&quot;normal&quot;&quot; and &quot;&quot;minimize&quot;&quot; values of the &quot;&quot;openstatus&quot;&quot; property are supported only in Windows NRE.&#xD;&#xA;The &quot;&quot;showtitlebar&quot;&quot; property is supported only in the Windows NRE environment.&#xD;&#xA;The “showstatusbar” property is supported only in Windows NRE.&quot;" />
            <Argument name="strReturnType" type="String" in="false" out="false" option="false" variable="false" description="&quot;Sets the return value type.&#xD;&#xA;If no value is specified, whether the modeless window is displayed successfully is returned.&#xD;&#xA;If a value is specified, the return value type is determined as follows.&#xD;&#xA;- &quot;&quot;promise&quot;&quot;: Returns a Promise object.&quot;" />
          </Arguments>
        </Syntax>
      </Method>
